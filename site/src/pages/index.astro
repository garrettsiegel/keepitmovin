58 0 0 1-.148.078c-.008 0-.015-.03-.015-.066a6.71 6.71 0 0 0-.097-.725C8.997 1.392 8.337.319 7.46.048a2.096 2.096 0 0 0-.585-.041Zm.293 1.402c.248.197.523.759.682 1.388.03.113.06.244.069.292.007.047.026.152.041.233.067.365.098.76.102 1.24l.002.475-.12.175-.118.178h-.278c-.324 0-.646.041-.954.124l-.238.06c-.033.007-.038-.003-.057-.144a8.438 8.438 0 0 1 .016-2.323c.124-.788.413-1.501.696-1.711.067-.05.079-.049.157.013zm9.825-.012c.17.126.358.46.498.888.28.854.36 2.028.212 3.145-.019.14-.024.151-.057.144l-.238-.06a3.693 3.693 0 0 0-.954-.124h-.278l-.119-.178-.119-.175.002-.474c.004-.669.066-1.19.214-1.772.157-.623.434-1.185.68-1.382.078-.062.09-.063.159-.012z",
};

const tools = [
  { name: "Claude Code", cmd: "claude", url: "https://code.claude.com/", icon: ICON.anthropic },
  { name: "Codex", cmd: "codex", url: "https://developers.openai.com/codex/", icon: ICON.openai },
  { name: "Kimi CLI", cmd: "kimi", url: "https://www.kimi.com/code/", mono: "K" },
  { name: "Google Antigravity", cmd: "agy", url: "https://antigravity.google/", icon: ICON.google },
  { name: "opencode", cmd: "opencode", url: "https://github.com/anomalyco/opencode", mono: "o" },
  { name: "Grok Build", cmd: "grok", url: "https://x.ai/cli", icon: ICON.x },
  { name: "Cursor Agent", cmd: "agent", url: "https://cursor.com/cli", mono: "C" },
  {
    name: "GitHub Copilot CLI",
    cmd: "copilot",
    url: "https://docs.github.com/en/copilot/how-tos/set-up/install-copilot-cli",
    icon: ICON.github,
  },
  { name: "Ollama", cmd: "ollama", url: "https://ollama.com/", tag: "local", icon: ICON.ollama },
];

const steps = [
  {
    num: "01",
    title: "A tool hits its limit",
    body: "keepitmovin watches the terminal and recognizes the exact limit message the moment it appears.",
  },
  {
    num: "02",
    title: "Your context is packed",
    body: "The handoff file carries your goal, decisions, and recent changes — refreshed as the tool works.",
  },
  {
    num: "03",
    title: "The next tool resumes",
    body: "It launches with the handoff loaded and picks up where you stopped. You keep typing.",
  },
];

const vs = [
  {
    label: "Hit a limit mid-task",
    kim: "The next tool starts automatically, context included.",
    raw: "You copy-paste what you remember into a new session.",
  },
  {
    label: "Context carried over",
    kim: "The handoff file is refreshed as your tools work.",
    raw: "Nothing — the new tool starts blank.",
  },
  {
    label: "Watching for failures",
    kim: "Limits, auth errors, and crashes are detected for you.",
    raw: "You watch the terminal yourself.",
  },
  {
    label: "Multi-tool setup",
    kim: "One setup wizard, zero config to start.",
    raw: "Juggle every CLI's flags and logins by hand.",
  },
];
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="kicker">one terminal · every tool you pay for</p>
      <h1>Agents hit limits. Your work <em>doesn't.</em></h1>
      <p class="subline">
        keepitmovin runs your coding agents in one terminal, watches for rate
        limits, and hands off to the next tool with full context — so you
        never stop mid-task.
      </p>
      <div class="hero-actions">
        <InstallCommand command="npm install -g keepitmovin" />
      </div>
      <p class="hero-note">
        Then run <code>kim</code>. A first-run wizard detects your installed
        tools and you pick a fallback order. Zero config to start.
      </p>
      <HandoffSim />
    </div>
  </section>

  <!-- Tools ticker -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      {
        [...tools, ...tools].map((t) => (
          <span>
            {t.icon ? (
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d={t.icon} />
              </svg>
            ) : (
              <span class="ticker-mono">{t.mono}</span>
            )}
            {t.name}
          </span>
        ))
      }
    </div>
  </div>

  <!-- 01 · How it works -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-num">01</span>
        <div>
          <h2>The handoff is <em>automatic.</em></h2>
          <p class="lede">
            When a tool hits its usage limit, keepitmovin detects the exact
            limit message and starts your next tool. No copy-pasting context,
            no lost thread, no "where was I".
          </p>
        </div>
      </div>
      <ol class="steps" data-reveal>
        {
          steps.map((step) => (
            <li>
              <span class="step-num">{step.num}</span>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
              <span class="step-arrow">»</span>
            </li>
          ))
        }
      </ol>
      <p class="aside">
        <span class="arrow">→</span> Switch on your own schedule: press
        <kbd>Ctrl+]</kbd> to hand off to the next tool anytime. Everything
        keepitmovin writes lives in <code>.keepitmovin/</code> in your project.
      </p>
    </div>
  </section>

  <!-- 02 · Comparison -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-num">02</span>
        <div>
          <h2>One long session, not <em>five short ones.</em></h2>
          <p class="lede">
            You already pay for these tools. keepitmovin chains their limits
            into one continuous working session.
          </p>
        </div>
      </div>
      <div class="vs" data-reveal>
        <div class="vs-panel kim">
          <h3>With keepitmovin</h3>
          <ul>
            {
              vs.map((row) => (
                <li>
                  <strong>{row.label}</strong>
                  {row.kim}
                </li>
              ))
            }
          </ul>
        </div>
        <div class="vs-panel raw">
          <h3>Running agents raw</h3>
          <ul>
            {
              vs.map((row) => (
                <li>
                  <strong>{row.label}</strong>
                  {row.raw}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 03 · Tools wall -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-num">03</span>
        <div>
          <h2>Works with the tools you <em>already use.</em></h2>
          <p class="lede">
            Nine tools supported today. keepitmovin detects what's installed;
            you pick the fallback order. Ollama sits last — a local fallback
            for advice and planning when every cloud tool is blocked.
          </p>
        </div>
      </div>
      <div class="tools-grid" data-reveal>
        {
          tools.map((tool) => (
            <a class="tool" href={tool.url} target="_blank" rel="noopener">
              <span class="tool-name">
                {tool.name}
                {tool.tag && <span class="tool-tag">{tool.tag}</span>}
              </span>
              <code class="tool-cmd">{tool.cmd}</code>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 04 · Honest limitation -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="section-num">04</span>
        <div class="pull">
          <p>
            When keepitmovin switches tools, the new tool starts a
            <em>fresh session.</em>
          </p>
          <p class="pull-sub">
            It gets the handoff file — your goal, decisions, and recent
            changes — not the previous tool's private chat history. No coding
            agent can transfer that today. That's the trade, stated plainly.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 05 · Pricing -->
  <section class="section" id="pricing">
    <div class="container">
      <div class="section-head">
        <span class="section-num">05</span>
        <div>
          <h2>Free where it runs. <em>Paid where it syncs.</em></h2>
          <p class="lede">
            The CLI is open source and free forever. The paid tiers are
            early-access — join the waitlist and we'll bring you on as they
            ship.
          </p>
        </div>
      </div>
      <div class="pricing" data-reveal>
        <!-- Free -->
        <div class="price-card">
          <div class="price-head">
            <h3>Free</h3>
            <p class="price">
              <span class="amount">$0</span><span class="per">forever</span>
            </p>
          </div>
          <p class="price-tagline">The full open-source CLI.</p>
          <ul class="price-features">
            <li>All nine tools</li>
            <li>Unlimited local use</li>
            <li>MIT licensed</li>
            <li>Zero config to start</li>
          </ul>
          <div class="price-cta">
            <InstallCommand command="npm install -g keepitmovin" />
          </div>
        </div>

        <!-- Pro -->
        <div class="price-card featured">
          <div class="price-head">
            <h3>Pro <span class="price-badge">coming soon</span></h3>
            <p class="price">
              <span class="amount">~$9</span><span class="per"
                >/mo · early access</span
              >
            </p>
          </div>
          <p class="price-tagline">Carry your handoffs across every machine.</p>
          <ul class="price-features">
            <li>Cloud handoff sync across machines</li>
            <li>Cross-tool usage dashboard</li>
            <li>Priority support</li>
            <li>Early access to new features</li>
          </ul>
          <div class="price-cta">
            <a
              class="price-btn"
              href="mailto:garrett@garrettsiegel.com?subject=keepitmovin%20Pro%20waitlist"
              >Join the waitlist</a
            >
          </div>
        </div>

        <!-- Team / Enterprise -->
        <div class="price-card">
          <div class="price-head">
            <h3>Team / Enterprise</h3>
            <p class="price"><span class="amount">Custom</span></p>
          </div>
          <p class="price-tagline">For orgs running agents at scale.</p>
          <ul class="price-features">
            <li>Shared handoff spaces</li>
            <li>Org policies</li>
            <li>SSO</li>
            <li>SLA</li>
          </ul>
          <div class="price-cta">
            <a
              class="price-btn ghost"
              href="mailto:garrett@garrettsiegel.com?subject=keepitmovin%20for%20teams"
              >Talk to us</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
