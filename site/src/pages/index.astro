---
import BaseLayout from "../layouts/BaseLayout.astro";
import InstallCommand from "../components/InstallCommand.astro";
import HandoffSim from "../components/HandoffSim.astro";

const title = "keepitmovin — Agents hit limits. Your work doesn't.";
const description =
  "keepitmovin runs your coding agents in one terminal, watches for rate limits, and hands off to the next tool with full context — so you never stop mid-task.";

// Brand marks — official simple-icons SVG path data (single-color, currentColor,
// 24×24 viewBox), inlined so there's no runtime dependency. Tools without a clean
// official mark fall back to a tasteful accent monogram.
