{
  "name": "codepass",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "bin": {
    "codepass": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "start": "node dist/cli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "execa": "^9.6.0",
    "node-pty": "^1.1.0",
    "ora": "^9.0.0",
    "strip-ansi": "^7.2.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.0.15"
  }
}
