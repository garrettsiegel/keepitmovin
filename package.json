{
  "name": "codepass",
  "version": "1.1.0",
  "description": "Interactive terminal harness that switches between coding agents (Claude Code, Codex, Antigravity, opencode, Cline) and carries a shared handoff file so you never lose context when a rate limit hits or you want to change tools.",
  "keywords": [
    "cli",
    "ai",
    "coding-agent",
    "claude-code",
    "codex",
    "harness",
    "terminal",
    "pty"
  ],
  "homepage": "https://github.com/garrettsiegel/codepass#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garrettsiegel/codepass.git"
  },
  "license": "MIT",
  "author": "Garrett Siegel",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "codepass": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "release": "bash scripts/release.sh",
    "start": "node dist/cli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "execa": "^9.6.0",
    "node-pty": "^1.1.0",
    "ora": "^9.0.0",
    "strip-ansi": "^7.2.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.0.15"
  }
}
