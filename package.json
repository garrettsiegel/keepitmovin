{
  "name": "keepitmovin",
  "version": "2.0.0",
  "description": "Run your AI coding tools (Claude Code, Codex, Kimi CLI, Google Antigravity, opencode, Grok Build, Cursor Agent, GitHub Copilot CLI, Ollama) in one terminal. When one hits its usage limit, keepitmovin hands the next tool a handoff file with your full context — so you never stop mid-task.",
  "keywords": [
    "cli",
    "ai",
    "coding-agent",
    "claude-code",
    "codex",
    "kimi",
    "moonshot",
    "antigravity",
    "opencode",
    "grok",
    "grok-build",
    "xai",
    "cursor",
    "cursor-agent",
    "github-copilot",
    "ollama",
    "keepitmovin",
    "rate-limit",
    "handoff",
    "terminal",
    "pty"
  ],
  "homepage": "https://github.com/garrettsiegel/keepitmovin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garrettsiegel/keepitmovin.git"
  },
  "license": "MIT",
  "author": "Garrett Siegel",
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "keepitmovin": "dist/cli.js",
    "kim": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "release": "bash scripts/release.sh",
    "start": "node dist/cli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "execa": "^9.6.0",
    "node-pty": "^1.1.0",
    "ora": "^9.0.0",
    "strip-ansi": "^7.2.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.0.15"
  }
}
