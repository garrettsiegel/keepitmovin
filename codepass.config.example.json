{
  "fallbackOn": [
    "rate_limit",
    "quota_exceeded",
    "auth_error",
    "timeout",
    "command_not_found",
    "nonzero_exit"
  ],
  "context": {
    "maxDiffChars": 20000
  },
  "logs": {
    "sessionsDir": ".codepass/sessions"
  },
  "updates": {
    "checkOnStart": true,
    "mode": "prompt",
    "includeDisabledProviders": false
  },
  "routing": {
    "enabled": false,
    "promptForTask": true,
    "allowOverride": true,
    "askOutcome": true,
    "telemetry": true
  },
  "harness": {
    "setupComplete": false,
    "providerOrder": ["claude", "codex", "antigravity", "opencode", "grok", "cursor"],
    "transcriptLimitChars": 80000,
    "handoffPath": ".codepass/current/handoff.md",
    "handoffArchiveDir": ".codepass/handoffs",
    "manualSwitchKey": "ctrl-]",
    "autoAppendCheckpoints": true,
    "providers": [
      {
        "name": "claude",
        "label": "Claude Code",
        "enabled": true,
        "command": "claude",
        "args": ["{{sessionPrompt}}"],
        "handoffArgs": ["{{handoffPrompt}}"],
        "integrationType": "pty",
        "controllable": true
      },
      {
        "name": "codex",
        "label": "Codex",
        "enabled": true,
        "command": "codex",
        "args": ["{{sessionPrompt}}"],
        "handoffArgs": ["{{handoffPrompt}}"],
        "integrationType": "pty",
        "controllable": true
      },
      {
        "name": "cline",
        "label": "Cline",
        "enabled": false,
        "command": "cline",
        "args": ["-i", "{{sessionPrompt}}"],
        "handoffArgs": ["-i", "{{handoffPrompt}}"],
        "integrationType": "pty",
        "controllable": true
      },
      {
        "name": "antigravity",
        "label": "Google Antigravity",
        "enabled": true,
        "command": "agy",
        "args": ["--prompt-interactive", "{{sessionPrompt}}"],
        "handoffArgs": ["--prompt-interactive", "{{handoffPrompt}}"],
        "integrationType": "pty",
        "controllable": true
      },
      {
        "name": "opencode",
        "label": "opencode",
        "enabled": true,
        "command": "opencode",
        "args": ["{{cwd}}", "--prompt", "{{sessionPrompt}}"],
        "handoffArgs": ["{{cwd}}", "--prompt", "{{handoffPrompt}}"],
        "integrationType": "pty",
        "controllable": true
      },
      {
        "name": "grok",
        "label": "Grok Build",
        "enabled": true,
        "command": "grok",
        "args": ["{{sessionPrompt}}"],
        "handoffArgs": ["{{handoffPrompt}}"],
        "integrationType": "pty",
        "controllable": true
      },
      {
        "name": "cursor",
        "label": "Cursor Agent",
        "enabled": true,
        "command": "agent",
        "args": ["{{sessionPrompt}}"],
        "handoffArgs": ["{{handoffPrompt}}"],
        "integrationType": "pty",
        "controllable": true
      },
      {
        "name": "ollama",
        "label": "Ollama",
        "enabled": false,
        "command": "ollama",
        "args": ["run", "llama3.2"],
        "handoffArgs": ["run", "llama3.2"],
        "integrationType": "pty_with_bootstrap_input",
        "bootstrapInput": "Read the CodePass handoff at {{handoffPath}} and continue the session (keep that file updated as you work).\n",
        "handoffBootstrapInput": "Read the CodePass handoff at {{handoffPath}} first, then continue from where the previous tool left off.\n",
        "controllable": true
      },
      {
        "name": "aider",
        "label": "Aider",
        "enabled": false,
        "command": "aider",
        "args": [],
        "handoffArgs": [],
        "integrationType": "pty_with_bootstrap_input",
        "bootstrapInput": "Read the CodePass handoff at {{handoffPath}} and continue the session (keep that file updated as you work).\n",
        "handoffBootstrapInput": "Read the CodePass handoff at {{handoffPath}} first, then continue from where the previous tool left off.\n",
        "controllable": true
      },
      {
        "name": "goose",
        "label": "Goose",
        "enabled": false,
        "command": "goose",
        "args": ["session"],
        "handoffArgs": ["session"],
        "integrationType": "pty_with_bootstrap_input",
        "bootstrapInput": "Read the CodePass handoff at {{handoffPath}} and continue the session (keep that file updated as you work).\n",
        "handoffBootstrapInput": "Read the CodePass handoff at {{handoffPath}} first, then continue from where the previous tool left off.\n",
        "controllable": true
      },
      {
        "name": "amp",
        "label": "Amp",
        "enabled": false,
        "command": "amp",
        "args": [],
        "handoffArgs": [],
        "integrationType": "pty_with_bootstrap_input",
        "bootstrapInput": "Read the CodePass handoff at {{handoffPath}} and continue the session (keep that file updated as you work).\n",
        "handoffBootstrapInput": "Read the CodePass handoff at {{handoffPath}} first, then continue from where the previous tool left off.\n",
        "controllable": true
      },
      {
        "name": "droid",
        "label": "Factory Droid",
        "enabled": false,
        "command": "droid",
        "args": ["{{sessionPrompt}}"],
        "handoffArgs": ["{{handoffPrompt}}"],
        "integrationType": "pty",
        "controllable": true
      },
      {
        "name": "copilot",
        "label": "GitHub Copilot CLI",
        "enabled": false,
        "command": "copilot",
        "args": [],
        "handoffArgs": [],
        "integrationType": "pty_with_bootstrap_input",
        "bootstrapInput": "Read the CodePass handoff at {{handoffPath}} and continue the session (keep that file updated as you work).\n",
        "handoffBootstrapInput": "Read the CodePass handoff at {{handoffPath}} first, then continue from where the previous tool left off.\n",
        "controllable": true
      }
    ]
  }
}
